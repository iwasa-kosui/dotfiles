{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "bun ./hooks/main-repo-shell-guard.ts",
        "failClosed": true
      },
      {
        "command": "bun ./hooks/main-branch-guard.ts",
        "failClosed": true
      },
      {
        "command": "bun ./hooks/force-push-guard.ts",
        "failClosed": true
      },
      {
        "command": "bun ./hooks/gh-comment-prefix-guard.ts",
        "failClosed": true
      }
    ],
    "beforeReadFile": [
      {
        "command": "bun ./hooks/secret-file-guard.ts",
        "failClosed": true
      }
    ],
    "preToolUse": [
      {
        "command": "bun ./hooks/secret-file-guard.ts",
        "matcher": "Write|StrReplace|Delete|EditNotebook|ApplyPatch",
        "failClosed": true
      },
      {
        "command": "bun ./hooks/main-repo-guard.ts",
        "matcher": "Write|StrReplace|Delete|EditNotebook|ApplyPatch",
        "failClosed": true
      },
      {
        "command": "bun ./hooks/main-repo-shell-guard.ts",
        "matcher": "Shell",
        "failClosed": true
      },
      {
        "command": "bun ./hooks/webfetch-guard.ts",
        "matcher": "WebFetch",
        "failClosed": true
      }
    ]
  }
}
