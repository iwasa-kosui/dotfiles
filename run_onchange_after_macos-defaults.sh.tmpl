#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}
set -euo pipefail

echo "Applying macOS defaults..."

###############################################################################
# NSGlobalDomain
###############################################################################

# Dark mode
defaults write NSGlobalDomain AppleInterfaceStyle -string "Dark"

# Show all file extensions in Finder
defaults write NSGlobalDomain AppleShowAllExtensions -bool true

# Disable automatic text corrections
defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled -bool false
defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false

# Always show scrollbars
defaults write NSGlobalDomain AppleShowScrollBars -string "Always"

# Disable minimize on title bar double-click
defaults write NSGlobalDomain AppleMiniaturizeOnDoubleClick -bool false

# Mouse: disable acceleration, speed 2
defaults write NSGlobalDomain com.apple.mouse.linear -bool true
defaults write NSGlobalDomain com.apple.mouse.scaling -float 2

# Trackpad: speed 2.5, disable force click
defaults write NSGlobalDomain com.apple.trackpad.scaling -float 2.5
defaults write NSGlobalDomain com.apple.trackpad.forceClick -bool false

# Alert sound
defaults write NSGlobalDomain com.apple.sound.beep.sound -string "/System/Library/Sounds/Tink.aiff"

###############################################################################
# Trackpad
###############################################################################

# Tap to click
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true

# Suppress Force Touch
defaults write com.apple.AppleMultitouchTrackpad ForceSuppressed -bool true
defaults write com.apple.AppleMultitouchTrackpad ActuateDetents -bool false

# Light click pressure
defaults write com.apple.AppleMultitouchTrackpad FirstClickThreshold -int 0
defaults write com.apple.AppleMultitouchTrackpad SecondClickThreshold -int 0

###############################################################################
# Dock
###############################################################################

defaults write com.apple.dock autohide -bool true
defaults write com.apple.dock tilesize -int 91
defaults write com.apple.dock expose-group-apps -bool true
defaults write com.apple.dock wvous-br-corner -int 14

killall Dock || true

###############################################################################
# Mission Control / Spaces
###############################################################################

defaults write com.apple.spaces spans-displays -bool true

###############################################################################
# Menu bar clock
###############################################################################

defaults write com.apple.menuextra.clock ShowSeconds -bool true
defaults write com.apple.menuextra.clock ShowAMPM -bool true

###############################################################################
# Finder
###############################################################################

defaults write com.apple.finder FXPreferredViewStyle -string "Nlsv"
defaults write com.apple.finder FXRemoveOldTrashItems -bool true

killall Finder || true

###############################################################################
# Screenshots
###############################################################################

defaults write com.apple.screencapture location -string "~/Documents/"

###############################################################################
# File associations (via Launch Services API)
###############################################################################

swift - <<'SWIFT'
import Foundation
import CoreServices

let dia = "company.thebrowser.dia" as NSString as CFString
let cmuxNvim = "com.local.open-in-cmux-nvim" as NSString as CFString
let cmux = "com.cmuxterm.app" as NSString as CFString

let utiHandlers: [(String, CFString)] = [
    ("public.plain-text", cmuxNvim),
    ("public.json", cmuxNvim),
    ("public.comma-separated-values-text", cmuxNvim),
    ("net.daringfireball.markdown", cmuxNvim),
    ("public.patch-file", cmuxNvim),
    ("com.microsoft.typescript", cmuxNvim),
    ("com.microsoft.typescript.tsx", cmuxNvim),
    ("public.html", dia),
    ("public.svg-image", dia),
]

let schemeHandlers: [(String, CFString)] = [
    ("https", dia),
    ("http", dia),
    ("mailto", dia),
    ("webcal", dia),
    ("ssh", cmux),
]

for (uti, handler) in utiHandlers {
    let status = LSSetDefaultRoleHandlerForContentType(uti as NSString as CFString, .all, handler)
    if status != 0 {
        print("Warning: failed to set handler for UTI \(uti): \(status)")
    }
}

for (scheme, handler) in schemeHandlers {
    let status = LSSetDefaultHandlerForURLScheme(scheme as NSString as CFString, handler)
    if status != 0 {
        print("Warning: failed to set handler for scheme \(scheme): \(status)")
    }
}

print("File associations applied.")
SWIFT

echo "macOS defaults applied."
{{ end -}}
