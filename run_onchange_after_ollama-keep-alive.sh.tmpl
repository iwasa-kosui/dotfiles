#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}
# ollama keep-alive agent hash: {{ include "Library/LaunchAgents/com.kosui.ollama-keep-alive.plist" | sha256sum }}
set -euo pipefail

plist="$HOME/Library/LaunchAgents/com.kosui.ollama-keep-alive.plist"
domain="gui/$(id -u)"

echo "Reloading ollama keep-alive LaunchAgent..."
launchctl bootout "$domain" "$plist" 2>/dev/null || true
launchctl bootstrap "$domain" "$plist"

# 次回ログインを待たず現セッションにも即時反映する
launchctl setenv OLLAMA_KEEP_ALIVE -1

# ollama が起動中なら FIM モデルを keep_alive=-1 で常駐させ、コールドスタートを今すぐ解消する
# （OpenAI 互換エンドポイントは keep_alive 非対応のためネイティブ /api/generate を使う）
if curl -sf -o /dev/null --max-time 2 http://localhost:11434/api/version; then
  echo "Pinning qwen2.5-coder:3b-base in memory..."
  curl -sf -o /dev/null --max-time 60 http://localhost:11434/api/generate \
    -d '{"model":"qwen2.5-coder:3b-base","keep_alive":-1}' || true
fi
{{ end -}}
